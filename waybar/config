[
  {
    "layer": "top",
    "position": "right",
    "height": "100%",
    "width": 34,
    "modules-left": ["custom/hour-tens", "custom/hour-ones", "custom/colon", "custom/minute-tens", "custom/minute-ones"],
    "modules-center": [],
    "modules-right": ["cpu", "bluetooth", "network", "pulseaudio", "battery"],

    "custom/hour-tens": {
      "exec": "date +'%H' | cut -c1",
      "interval": 1,
      "format": "{}"
    },

    "custom/hour-ones": {
      "exec": "date +'%H' | cut -c2",
      "interval": 1,
      "format": "{}"
    },

    "custom/colon": {
      "exec": "echo ':'",
      "interval": 1,
      "format": "{}"
    },

    "custom/minute-tens": {
      "exec": "date +'%M' | cut -c1",
      "interval": 1,
      "format": "{}"
    },

    "custom/minute-ones": {
      "exec": "date +'%M' | cut -c2",
      "interval": 1,
      "format": "{}"
    },

    "battery": {
      "format": "{capacity}%",
      "format-charging": "<span foreground='#EED49F'>{icon} {capacity}َ±گ‹</span>",
      "interval": 10
    },

    "pulseaudio": {
      "format": "{icon}",
      "format-muted": "َ°–پ",
      "format-icons": {
        "default": ["َ°•؟", "َ°–€", "َ°•¾"]
      },
      "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
      "on-click-right": "pavucontrol",
      "scroll-step": 1,
      "tooltip": false
    },

    "network": {
      "format": "{ifname}",
      "format-wifi": "َ°–© ",
      "format-ethernet": "َ°ˆ€ ",
      "format-disconnected": "َ°–ھ ",
      "tooltip-format": "{ifname} via {gwaddr} ({ipaddr}/{cidr})\\n{essid} ({signalStrength}%)",
      "on-click": "networkmanager_dmenu",
      "on-click-right": "alacritty -e nmtui"
    },

    "bluetooth": {
      "format-on": "َ°‚¯",
      "format-connected": "َ°‚¯",
      "format-off": "َ°‚²",
      "on-click": "blueman-manager"
    },

    "cpu": {
      "format": "{usage}%",
      "interval": 2
    }
  },
  {
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": [],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [],

    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "default": "َ°„°",
        "active": "î®´",
        "1": "ï†¼",
        "2": "َ±پچ",
        "3": "َ±،‌",
        "4": "ï…„"
      },
      "persistent-workspaces": {
        "*": [1, 2, 3, 4, 5]
      }
    }
  },
  {
    "layer": "top",
    "position": "left",
    "height": "100%",
    "width": 24,
    "modules-left": [],
    "modules-center": [],
    "modules-right": []
  },
  {
    "layer": "top",
    "position": "bottom",
    "height": 20,
    "modules-left": [],
    "modules-center": [],
    "modules-right": []
  }
]
